{
    "$schema": "vendor/phpbench/phpbench/phpbench.schema.json",
    "runner.bootstrap": "vendor/autoload.php",
    "runner.path": "tests/Benchmark",
    "runner.file_pattern": "*Bench.php",
    "runner.php_config": {
        "opcache.enable_cli": "1",
        "opcache.jit": "tracing",
        "opcache.jit_buffer_size": "64M",
        "memory_limit": "256M"
    }
}
